{
  "name": "@kiana/media-service",
  "version": "0.1.0",
  "private": true,
  "description": "Upload metadata, transcoding state, signed URLs. Owns media_db.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "echo \"media-service: tests scaffolded\"",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@kiana/contracts": "workspace:*",
    "@kiana/db-kit": "workspace:*",
    "@kiana/service-kit": "workspace:*",
    "drizzle-orm": "^0.30.0",
    "fastify": "^4.26.0"
  },
  "devDependencies": {
    "@kiana/config": "workspace:*",
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
