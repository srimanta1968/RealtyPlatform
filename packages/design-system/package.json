{
  "name": "@kiana/design-system",
  "version": "0.1.0",
  "private": true,
  "description": "Tailwind preset + Radix-based React component library shared across all Kiana frontends.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tailwind-preset": "./tailwind.preset.cjs",
    "./styles.css": "./src/styles.css"
  },
  "files": ["dist", "src/styles.css", "tailwind.preset.cjs"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "echo \"@kiana/design-system: no tests yet\"",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@kiana/config": "workspace:*",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3"
  }
}
