{
  "name": "@kiana/service-kit",
  "version": "0.1.0",
  "private": true,
  "description": "Fastify base, structured logger, OTel hooks, JWT auth middleware, health checks.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "echo \"@kiana/service-kit: no tests yet\"",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/sensible": "^5.5.0",
    "@kiana/contracts": "workspace:*",
    "fastify": "^4.26.0",
    "fastify-plugin": "^4.5.1",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@kiana/config": "workspace:*",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3"
  }
}
