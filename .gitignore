# =====================================================
# Root .gitignore - Kiana Realty Growth Platform
# =====================================================

# Environment files (NEVER commit these!)
.env
.env.local
.env.*.local
*.env

# IDE and editors
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.shared.json

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependencies (installed locally)
node_modules/
.pnpm-store/
vendor/
__pycache__/
*.pyc
venv/
.venv/

# Build outputs
dist/
build/
out/
target/
bin/
obj/
.next/
.turbo/
*.tsbuildinfo

# Test coverage
coverage/
.nyc_output/
htmlcov/

# Docker
docker-compose.override.yml

# Database files (local)
*.sqlite
*.sqlite3
*.db
data/

# Temporary files
tmp/
temp/
*.tmp

# Generated documentation
docs/_build/

# Secrets and keys
*.pem
*.key
credentials.json
serviceAccount.json

# ProjexLight runtime artifacts (do NOT commit feedback / cache)
.projexlight/feedback/
.projexlight/cache/
.projexlight/violations/
.projexlightlocal/

# MCP secrets
mcp-server/.env
mcp-server/mcp-config.json
.mcp-cache/

# Tests artefacts
tests/reports/
tests/screenshots/
tests/config/.auth-session.json
