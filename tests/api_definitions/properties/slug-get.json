{
  "name": "GET /api/properties/:slug - Public property detail by slug",
  "endpoint": "/api/properties/:slug",
  "method": "GET",
  "taskId": "73542164-6b9d-4d2e-ace6-6df1bd1b2ae6",
  "sprintId": "a5c410ab-2b62-45f5-9190-8b601499f543",
  "requiresAuth": false,
  "priority": 55,
  "description": "Public detail endpoint that powers /properties/<slug> on web-public. 404s for unpublished slugs (status != 'published') so direct lookups can't leak DRAFT / HOLD / SOLD rows.",
  "dependsOn": [
    "POST /api/auth/register",
    "POST /api/auth/login",
    "POST /api/properties",
    "PATCH /api/properties/:id/publish"
  ],
  "testCases": [
    {
      "name": "Fetch a published property by slug",
      "pathParams": {
        "slug": "{{cache:properties.create.response.data.property.slug}}"
      },
      "expectedStatus": 200,
      "expectedResponse": {
        "success": true,
        "data": {
          "property": {
            "id": "<string>",
            "slug": "<string>",
            "status": "<string>"
          }
        }
      }
    }
  ]
}
