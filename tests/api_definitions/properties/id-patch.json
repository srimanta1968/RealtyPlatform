{
  "name": "PATCH /api/properties/:id - Admin updates a property",
  "endpoint": "/api/properties/:id",
  "method": "PATCH",
  "taskId": "a9dba0f3-0c12-4d68-82dd-8758ced22f31",
  "sprintId": "a5c410ab-2b62-45f5-9190-8b601499f543",
  "requiresAuth": true,
  "requiresRole": [
    "admin"
  ],
  "priority": 35,
  "description": "Admin-only partial update. Validates against PropertyUpdateRequestSchema (at least one field must be present); price-range invariant re-checked. 404 when the id is gone, 400 on inverted ranges or invalid enum values.",
  "dependsOn": [
    "POST /api/auth/register",
    "POST /api/auth/login",
    "POST /api/properties"
  ],
  "testCases": [
    {
      "name": "Update a property's title and tags",
      "headers": {
        "Authorization": "Bearer {{cache:auth.login.response.data.token}}"
      },
      "pathParams": {
        "id": "{{cache:properties.create.response.data.property.id}}"
      },
      "payload": {
        "title": "{{static:Lonavala Hilltop Villa - Updated}}",
        "tags": [
          "villa",
          "lonavala",
          "premium"
        ]
      },
      "expectedStatus": 200,
      "expectedResponse": {
        "success": true,
        "data": {
          "property": {
            "id": "<string>",
            "slug": "<string>",
            "title": "<string>"
          }
        }
      }
    }
  ]
}
