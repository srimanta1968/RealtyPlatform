{
  "name": "POST /api/users/invite - Admin issues a staff invite",
  "endpoint": "/api/users/invite",
  "method": "POST",
  "taskId": "ad563107-0910-415e-bd6b-af73a612eb99",
  "sprintId": "a5c410ab-2b62-45f5-9190-8b601499f543",
  "requiresAuth": true,
  "requiresRole": [
    "admin"
  ],
  "priority": 80,
  "description": "Admin-only invite issue. Persists a one-shot token in staff_invites with the future role baked in (so the accept handler can't be tricked into elevating role), then dispatches an invite email through the existing notification path. Customer role is rejected (customers self-register).",
  "dependsOn": [
    "POST /api/auth/register",
    "POST /api/auth/login"
  ],
  "captureResponse": {
    "users.invite.response.data.invite.id": "data.invite.id",
    "users.invite.response.data.token": "data.token"
  },
  "testCases": [
    {
      "name": "Invite a presales staffer",
      "headers": {
        "Authorization": "Bearer {{cache:auth.login.response.data.token}}"
      },
      "payload": {
        "email": "{{dynamic:email}}",
        "role": "{{static:presales}}",
        "full_name": "{{dynamic:name}}"
      },
      "expectedStatus": 201,
      "expectedResponse": {
        "success": true,
        "data": {
          "invite": {
            "id": "<string>",
            "email": "<string>",
            "role": "<string>"
          }
        }
      }
    }
  ]
}
