{
  "name": "GET /api/leads/:id - Fetch a single captured lead by id",
  "endpoint": "/api/leads/:id",
  "method": "GET",
  "taskId": "809859b7-e3a1-472c-b48e-31420f75e2cc",
  "sprintId": "a5c410ab-2b62-45f5-9190-8b601499f543",
  "requiresAuth": true,
  "priority": 45,
  "description": "Operator-facing endpoint behind the admin-cockpit Lead Detail screen. Returns the canonical LeadRecord; 404 when the id does not resolve to a row.",
  "dependsOn": ["POST /api/auth/register", "POST /api/leads"],
  "testCases": [
    {
      "name": "Fetch the lead created by the POST /api/leads chain",
      "headers": {
        "Authorization": "Bearer {{cache:auth.register.response.data.token}}"
      },
      "pathParams": {
        "id": "{{cache:leads.create.response.data.lead.id}}"
      },
      "expectedStatus": 200,
      "expectedResponse": {
        "success": true,
        "data": {
          "lead": {
            "id": "<string>",
            "full_name": "<string>",
            "source": "<string>",
            "stage": "<string>"
          }
        }
      }
    }
  ]
}
