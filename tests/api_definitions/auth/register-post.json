{
  "name": "POST /api/auth/register - User registration",
  "endpoint": "/api/auth/register",
  "method": "POST",
  "taskId": "2dc248ab-3da4-4621-8148-d411e7ff4582",
  "sprintId": "a5c410ab-2b62-45f5-9190-8b601499f543",
  "requiresAuth": false,
  "priority": 10,
  "description": "Register a new Kiana user with email + password and return a signed JWT plus public user payload.",
  "captureResponse": {
    "auth.register.response.data.token": "data.token",
    "auth.register.response.data.user.id": "data.user.id",
    "auth.register.response.data.user.email": "data.user.email"
  },
  "testCases": [
    {
      "name": "Register a new user with email and password",
      "payload": {
        "email": "{{dynamic:email}}",
        "password": "{{dynamic:password}}"
      },
      "expectedStatus": 201,
      "expectedResponse": {
        "success": true,
        "data": {
          "token": "<string>",
          "user": {
            "email": "<string>"
          }
        }
      }
    }
  ]
}
