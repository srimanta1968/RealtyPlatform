{
  "name": "POST /api/auth/register - User registration",
  "endpoint": "/api/auth/register",
  "method": "POST",
  "taskId": "2dc248ab-3da4-4621-8148-d411e7ff4582",
  "sprintId": "a5c410ab-2b62-45f5-9190-8b601499f543",
  "requiresAuth": false,
  "priority": 10,
  "description": "Register a new Kiana user with email + password. Issues a signed JWT plus a one-time email-verification token (token field present in non-production environments only). Uses a static password so the chained login test can re-use the same value.",
  "captureResponse": {
    "auth.register.response.data.token": "data.token",
    "auth.register.response.data.user.id": "data.user.id",
    "auth.register.response.data.user.email": "data.user.email",
    "auth.register.response.data.verification.token": "data.verification.token"
  },
  "testCases": [
    {
      "name": "Register a new user with email and password",
      "payload": {
        "full_name": "{{dynamic:name}}",
        "email": "{{dynamic:email}}",
        "password": "{{static:KianaTest_2025!}}"
      },
      "expectedStatus": 201,
      "expectedResponse": {
        "success": true,
        "data": {
          "token": "<string>",
          "user": {
            "email": "<string>"
          },
          "verification": {
            "expires_at": "<string>"
          }
        }
      }
    }
  ]
}
